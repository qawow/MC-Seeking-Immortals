# =====================================================================
# 寻仙问道 Minecraft Mod — Forge 1.20.1 / Gradle
# .gitignore
# =====================================================================


# ── Gradle ───────────────────────────────────────────────────────────
.gradle/
build/
out/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Gradle wrapper verify
gradle-wrapper.jar.sha256

# ── ForgeGradle & MDK ────────────────────────────────────────────────
# ForgeGradle caches (large, always re-downloadable)
.forge/
fg_cache/
minecraft_mapped_production/

# Decompiled Minecraft sources (generated by genSources)
src/main/java/net/minecraft/

# Run directories generated by Forge
run/
runs/

# AT (Access Transformer) Eclipse-side residue
eclipse/

# ── Java Compiled Output ─────────────────────────────────────────────
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar

# ── IDE: IntelliJ IDEA ───────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
# Keep run configs if committed deliberately:
# !.idea/runConfigurations/

# ── IDE: Eclipse ─────────────────────────────────────────────────────
.settings/
.classpath
.project
bin/

# ── IDE: Visual Studio Code ──────────────────────────────────────────
.vscode/
*.code-workspace

# ── OS Junk ──────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Logs & Crash Reports ─────────────────────────────────────────────
logs/
crash-reports/
*.log
*.log.gz
latest.log
debug.log

# ── Minecraft Runtime Data ───────────────────────────────────────────
# These appear in run/ dirs during dev
saves/
screenshots/
resourcepacks/
shaderpacks/
options.txt
servers.dat
usercache.json
usernamecache.json

# ── Sensitive / Local Config ─────────────────────────────────────────
# Local override properties (API keys, personal paths, etc.)
local.properties
gradle.properties.local
secrets.properties

# ── Texture / Asset Work-in-Progress ─────────────────────────────────
# Uncomment if you keep WIP assets in a scratch folder
# src/main/resources/assets/seeking_immortals/wip/

# Aseprite project files (keep .png exports, ignore source)
*.aseprite
*.ase

# Photoshop / GIMP working files
*.psd
*.xcf

# ── Mod Distribution ─────────────────────────────────────────────────
# Built mod JARs — let CI publish; don't commit binaries
dist/
libs/
*.jar
# Exception: keep any bundled third-party libs you vendor intentionally
# !libs/some-shaded-lib.jar

# ── Project-specific (寻仙问道 local layout) ──────────────────────────
# Backup directories (hand-made or tooling-generated)
.bak/
backups/
manual_backups/

# Local JDK installations managed by IntelliJ / Gradle toolchain
.jdks/

# Claude Code project config (settings, commands, etc.)
# Commit .claude/ only if you want to share Claude Code instructions with collaborators;
# otherwise keep it local.
.claude/

# Code-graph index (generated by .codegraph tooling)
.codegraph/

# ── Misc ─────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.orig
nohup.out
